{
  "name": "@orbit-ai/demo-seed",
  "version": "0.1.0-alpha.0",
  "description": "Deterministic multi-tenant demo dataset for Orbit AI — designed to power E2E tests, starters, and demo content.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "crm",
    "ai-agents",
    "orbit-ai",
    "demo-data",
    "seed"
  ],
  "author": "Orbit AI Contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sharonds/orbit-ai.git",
    "directory": "packages/demo-seed"
  },
  "homepage": "https://github.com/sharonds/orbit-ai#readme",
  "bugs": {
    "url": "https://github.com/sharonds/orbit-ai/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" }
  },
  "files": [
    "dist",
    "!dist/**/__tests__/**",
    "!dist/**/*.test.*",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "rm -rf dist node_modules/.cache/tsconfig.demo-seed.tsbuildinfo && tsc",
    "prepack": "pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@orbit-ai/core": "workspace:*",
    "seedrandom": "^3.0.5"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/seedrandom": "^3.0.8",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "publishConfig": { "access": "public" }
}
