{
  "name": "@orbit-ai/demo-seed",
  "version": "0.1.0-alpha.0",
  "description": "Deterministic multi-tenant demo dataset for Orbit AI — designed to power E2E tests, starters, and demo content.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "rm -rf dist node_modules/.cache/tsconfig.demo-seed.tsbuildinfo && tsc",
    "prepack": "pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@orbit-ai/core": "workspace:*",
    "seedrandom": "^3.0.5"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/seedrandom": "^3.0.8",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "publishConfig": { "access": "public" }
}
