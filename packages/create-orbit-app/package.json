{
  "name": "@orbit-ai/create-orbit-app",
  "version": "0.1.0-alpha.0",
  "description": "Scaffold a new Orbit AI starter in under 60 seconds. Alpha usage: npx @orbit-ai/create-orbit-app@alpha my-app",
  "keywords": [
    "crm",
    "ai-agents",
    "orbit-ai",
    "typescript",
    "scaffolder",
    "starter"
  ],
  "author": "Orbit AI Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sharonds/orbit-ai.git",
    "directory": "packages/create-orbit-app"
  },
  "homepage": "https://github.com/sharonds/orbit-ai#readme",
  "bugs": {
    "url": "https://github.com/sharonds/orbit-ai/issues"
  },
  "type": "module",
  "bin": {
    "create-orbit-app": "./bin/create-orbit-app.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" }
  },
  "files": [
    "bin",
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc",
    "prepack": "pnpm run build",
    "prepublishOnly": "pnpm run build && node dist/publishGuard.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^0.8.2",
    "execa": "^9.5.0"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  }
}
