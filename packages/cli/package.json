{
  "name": "@orbit-ai/cli",
  "version": "0.1.0-alpha.0",
  "description": "Terminal interface for Orbit AI CRM",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "crm",
    "ai-agents",
    "orbit-ai",
    "cli",
    "typescript"
  ],
  "author": "Orbit AI Contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sharonds/orbit-ai.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/sharonds/orbit-ai#readme",
  "bugs": {
    "url": "https://github.com/sharonds/orbit-ai/issues"
  },
  "bin": {
    "orbit": "dist/index.js"
  },
  "files": [
    "dist/",
    "!dist/**/__tests__/**",
    "!dist/**/*.test.*",
    "!dist/**/fixtures/**",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "rm -rf dist && tsc && chmod +x dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@orbit-ai/core": "workspace:*",
    "@orbit-ai/integrations": "workspace:*",
    "@orbit-ai/sdk": "workspace:*",
    "cli-table3": "^0.6.0",
    "commander": "^14.0.3",
    "drizzle-orm": "^0.44.5",
    "ink": "^5.0.0",
    "pg": "^8.11.0",
    "react": "^18.0.0"
  },
  "devDependencies": {
    "@types/pg": "^8.15.5",
    "@types/react": "^18.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
