# ─────────────────────────────────────────────────────────────────────────────
# Orbit AI — environment variable reference
# Copy this file to .env and fill in the values for your environment.
# Lines starting with # are comments. Values shown are examples only.
# ─────────────────────────────────────────────────────────────────────────────

# ── Postgres adapter ──────────────────────────────────────────────────────────

# Primary database connection string (required when using the Postgres adapter).
# DATABASE_URL=postgresql://user:password@localhost:5432/orbit_ai

# Optional separate connection used exclusively for running migrations.
# Defaults to DATABASE_URL when not set.
# MIGRATION_DATABASE_URL=postgresql://migrator:password@localhost:5432/orbit_ai

# ── Supabase adapter (optional — uses Postgres adapter under the hood) ────────

# Your Supabase project URL.
# SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon (public) key — safe to expose to browsers.
# SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase service role key — NEVER expose this to browsers or commit it.
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── @orbit-ai/api server ──────────────────────────────────────────────────────

# Port the Hono API server listens on. Defaults to 3001.
# ORBIT_API_PORT=3001

# API version string returned in every response's meta.version field.
# ORBIT_API_VERSION=0.1.0-alpha

# Maximum HTTP request body size in bytes. Defaults to 1048576 (1 MB).
# ORBIT_MAX_REQUEST_BODY_SIZE=1048576

# ── @orbit-ai/sdk client ──────────────────────────────────────────────────────

# API key for authenticating SDK requests against the Orbit AI API server.
# ORBIT_API_KEY=sk_your_secret_key_here

# Base URL of the Orbit AI API server the SDK connects to.
# ORBIT_API_BASE_URL=http://localhost:3001

# ── Development / testing ─────────────────────────────────────────────────────

# Node environment. Set to 'test' for vitest runs, 'production' for deployments.
# NODE_ENV=development
